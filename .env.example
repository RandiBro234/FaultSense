# Salin file ini menjadi `.env` lalu sesuaikan nilainya.
# Hostname `postgres` adalah nama service di docker-compose; ganti ke
# `localhost:5433` bila menjalankan API langsung di host (di luar Docker).
DATABASE_URL=postgresql://faultsense_user:faultsense_pass@postgres:5432/faultsense_db

POSTGRES_DB=faultsense_db
POSTGRES_USER=faultsense_user
POSTGRES_PASSWORD=faultsense_pass

# ── pgAdmin 4 ───────────────────────────────────────────────
PGADMIN_EMAIL=admin@faultsense.com
PGADMIN_PASSWORD=admin123